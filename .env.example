VITE:SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Note: Sensitive API keys (KASSALAPP_API_KEY, LOVABLE_API_KEY, OPENAI_API_KEY)
